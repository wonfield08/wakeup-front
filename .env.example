# ─── 로컬 개발 (.env.local에 복사해서 사용) ───────────────────────────────────

# Vite dev server proxy 대상 (로컬 eye-status-api 주소)
# vite.config.ts가 /api/eye-status → 이 주소로 프록시합니다
VITE_EYE_STATUS_API_URL=http://127.0.0.1:8123


# ─── Vercel 배포 (Vercel 대시보드 > Settings > Environment Variables) ──────────

# eye-status-api의 공개 URL (Vercel 서버리스 함수가 여기로 요청 전달)
# VITE_ 접두사 없음 — 서버 사이드 전용
EYE_STATUS_API_URL=https://your-eye-status-api.example.com
